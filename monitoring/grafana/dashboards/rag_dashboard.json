{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "End-to-end monitoring for the RAG Telemetry & Evals pipeline. Covers request rate, error rate, and per-stage latency (retrieval, reranking, generation).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "title": "Total Requests",
      "type": "stat",
      "description": "Cumulative requests to POST /query since process start.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "graphMode": "area",
        "colorMode": "background",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rag_requests_total{endpoint=\"/query\"})",
          "legendFormat": "Requests",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "title": "Error Rate",
      "type": "stat",
      "description": "Percentage of /query requests that returned 4xx or 5xx.",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "graphMode": "area",
        "colorMode": "background",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(rag_requests_total{endpoint=\"/query\",http_status=~\"[45]..\"}[5m])) / sum(rate(rag_requests_total{endpoint=\"/query\"}[5m])) * 100",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "P95 Pipeline Latency",
      "type": "stat",
      "description": "95th-percentile total RAG pipeline duration (retrieval + reranking + generation).",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "graphMode": "area",
        "colorMode": "background",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 25 }
            ]
          },
          "unit": "s",
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_pipeline_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "title": "Active Requests",
      "type": "stat",
      "description": "Number of requests currently in-flight (Gauge).",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "graphMode": "none",
        "colorMode": "background",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rag_requests_in_flight",
          "legendFormat": "In-flight",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "title": "Request Rate",
      "type": "timeseries",
      "description": "Requests per second to POST /query, split by success vs error.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "spanNulls": true, "showPoints": "never" },
          "unit": "reqps",
          "min": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Errors" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(rag_requests_total{endpoint=\"/query\",http_status=~\"2..\"}[2m])",
          "legendFormat": "2xx Success",
          "refId": "A"
        },
        {
          "expr": "rate(rag_requests_total{endpoint=\"/query\",http_status=~\"[45]..\"}[2m])",
          "legendFormat": "Errors",
          "refId": "B"
        }
      ]
    },

    {
      "id": 6,
      "title": "Errors by Type",
      "type": "timeseries",
      "description": "Rate of errors broken down by error class (ValueError, GeminiClientError, etc.).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "spanNulls": true, "showPoints": "never" },
          "unit": "reqps",
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (error_type) (rate(rag_errors_total[2m]))",
          "legendFormat": "{{error_type}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 7,
      "title": "HTTP Request Duration — Percentiles",
      "type": "timeseries",
      "description": "P50 / P95 / P99 of total FastAPI request duration (wall clock, includes all stages and FastAPI overhead).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "spanNulls": true, "showPoints": "never" },
          "unit": "s",
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rag_request_duration_seconds_bucket{endpoint=\"/query\"}[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_request_duration_seconds_bucket{endpoint=\"/query\"}[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(rag_request_duration_seconds_bucket{endpoint=\"/query\"}[5m])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },

    {
      "id": 8,
      "title": "Pipeline Duration — Percentiles",
      "type": "timeseries",
      "description": "P50 / P95 of the RAG pipeline itself: retrieval + reranking + generation (excludes FastAPI overhead).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "spanNulls": true, "showPoints": "never" },
          "unit": "s",
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rag_pipeline_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_pipeline_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        }
      ]
    },

    {
      "id": 9,
      "title": "Retrieval Latency (ChromaDB)",
      "type": "timeseries",
      "description": "P50 / P95 latency for the ChromaDB vector search stage. Expect 5–200 ms for a local PersistentClient.",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true, "showPoints": "never" },
          "unit": "s",
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rag_retrieval_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_retrieval_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        }
      ]
    },

    {
      "id": 10,
      "title": "Reranking Latency (Cross-Encoder)",
      "type": "timeseries",
      "description": "P50 / P95 latency for the cross-encoder reranking stage. Zero when use_reranker=false. Expect 50–500 ms on CPU.",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true, "showPoints": "never" },
          "unit": "s",
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rag_reranking_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_reranking_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        }
      ]
    },

    {
      "id": 11,
      "title": "Generation Latency (Gemini)",
      "type": "timeseries",
      "description": "P50 / P95 Gemini API round-trip latency. Expect 1–15 s depending on response length and model load.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 20 },
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true, "showPoints": "never" },
          "unit": "s",
          "min": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rag_generation_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_generation_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        }
      ]
    },

    {
      "id": 12,
      "title": "Average Stage Duration Breakdown",
      "type": "timeseries",
      "description": "Rolling average latency per pipeline stage — use this to identify which stage dominates total latency. Generation almost always dominates; retrieval should be <100 ms.",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 28 },
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": true,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "s",
          "min": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Retrieval (avg)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Reranking (avg)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Generation (avg)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(rag_retrieval_duration_seconds_sum[5m]) / rate(rag_retrieval_duration_seconds_count[5m])",
          "legendFormat": "Retrieval (avg)",
          "refId": "A"
        },
        {
          "expr": "rate(rag_reranking_duration_seconds_sum[5m]) / rate(rag_reranking_duration_seconds_count[5m])",
          "legendFormat": "Reranking (avg)",
          "refId": "B"
        },
        {
          "expr": "rate(rag_generation_duration_seconds_sum[5m]) / rate(rag_generation_duration_seconds_count[5m])",
          "legendFormat": "Generation (avg)",
          "refId": "C"
        }
      ]
    }

  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["rag", "mlops", "llm"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "RAG Telemetry & Evals — Pipeline Monitor",
  "uid": "rag-pipeline-monitor",
  "version": 1,
  "weekStart": ""
}
